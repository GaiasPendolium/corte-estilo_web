# Django Settings - Production
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-in-production-12345
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/peluqueria_db

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com

# QZ Tray signing (produccion)
# Pega PEM completo incluyendo lineas BEGIN/END
QZ_CERT_PEM=
QZ_PRIVATE_KEY_PEM=
QZ_ALLOWED_ORIGINS=https://corte-estilo-web.vercel.app
