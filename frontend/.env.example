VITE_API_URL=http://localhost:8000/api
VITE_TICKET_BUSINESS_NAME=CORTE Y ESTILO
VITE_QZ_DEFAULT_PRINTER=
VITE_QZ_WS_HOST=localhost
VITE_QZ_WS_PORT_SECURE=8181
VITE_QZ_WS_PORT_INSECURE=8282
VITE_QZ_DRAWER_PIN=0
VITE_QZ_DRAWER_ON_MS=25
VITE_QZ_DRAWER_OFF_MS=250

# Produccion (firmado recomendado)
# VITE_QZ_CERT_PEM=-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----
# VITE_QZ_SIGN_ENDPOINT=https://tu-backend.com/api/qz

# Modo impresion: qz (default) o bridge (evita permisos de sitio QZ)
# VITE_PRINT_MODE=qz

# Modo apertura cajon: qz | serial | bridge
# VITE_DRAWER_MODE=qz

# Bridge local SAT (si usas VITE_PRINT_MODE=bridge o VITE_DRAWER_MODE=bridge)
# VITE_POS_BRIDGE_URL=http://127.0.0.1:8787
# VITE_POS_BRIDGE_PRINTER=POSPrinter POS-80
# VITE_POS_BRIDGE_TIMEOUT_MS=2500
